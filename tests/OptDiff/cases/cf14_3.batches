# Transcribed from cf14_3.main.cpp. The driver dumps reach_f and live_f
# after batches 2 and 3 (2 interleaved dumps); only the final state is
# checked here. edge is a non-differential message: add-only ops.

batch
+ input 1
+ input 2
+ input 5
end

batch
+ edge 1 2
+ edge 2 3
+ edge 5 6
end

batch
+ input 7
- input 1
end
