# Transcribed from transitive_closure_diff2.main.cpp: 2 driver sends
# (identical batch sequence to transitive_closure_diff; the case differs
# only in the .dr rule formulation). found_path is publish-only and never
# sent by the driver.

batch
+ add_edge 1 2
+ add_edge 2 3
+ add_edge 3 4
+ add_edge 7 8
end

batch
+ add_edge 4 7
+ add_edge 8 1
- add_edge 2 3
end
