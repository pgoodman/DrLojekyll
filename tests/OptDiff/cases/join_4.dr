; Corner case: constant-pivots-degrade-to-product. The only pivot column A is
; the constant 1 in both views, but non-constant non-pivot columns (B and C)
; remain spread across two views, so the JOIN survives with num_pivots = 0,
; i.e. becomes a PRODUCT.

#message m1(i32 A, i32 B).
#message m2(i32 A, i32 C).

#local t1(i32 A, i32 B).
#local t2(i32 A, i32 C).

t1(A, B) : m1(A, B).
t2(A, C) : m2(A, C).

#query q(free i32 B, free i32 C).
q(B, C) : t1(1, B), t2(1, C).
