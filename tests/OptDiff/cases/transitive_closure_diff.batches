# never sends it, so no ops reference it here.

batch
+ add_edge 1 2
+ add_edge 2 3
+ add_edge 3 4
+ add_edge 7 8
end

batch
+ add_edge 4 7
+ add_edge 8 1
- add_edge 2 3
end
